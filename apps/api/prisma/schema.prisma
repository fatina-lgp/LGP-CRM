generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(AGENT)
  leads        Lead[]     @relation("AssignedLeads")
  activities   Activity[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

model Lead {
  id          String     @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  company     String?
  source      String?
  stage       Stage      @default(NEW)
  notes       String?
  assigneeId  String?
  assignee    User?      @relation("AssignedLeads", fields: [assigneeId], references: [id])
  activities  Activity[]
  stageChangedAt DateTime @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("leads")
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType @default(NOTE)
  body      String
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("activities")
}

enum Stage {
  NEW
  CONTACTED
  CALL_BOOKED
  CALL_COMPLETED
  INTAKE_COMPLETED
  PROPOSAL
  NEGOTIATIONS
  CONTRACT_AND_PAYMENT
  CLOSED_WON
  CLOSED_LOST
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  TASK
}
