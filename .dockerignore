# Version control
.git
.gitignore

# Node
node_modules
**/node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Build outputs (rebuilt in Docker)
packages/*/dist
packages/twenty-front/build
.nx/cache

# Local env files (NEVER in Docker images)
.env
.env.*
packages/**/.env
packages/**/.env.*

# Dev tooling
.github
.storybook
**/*.stories.ts
**/*.stories.tsx
**/*.spec.ts
**/*.test.ts
**/*.e2e-spec.ts
coverage
.nyc_output

# OS & IDE
.DS_Store
Thumbs.db
.idea
.vscode
*.swp

# Docs / website (not needed in server image)
packages/twenty-docs
packages/twenty-website

# Prisma / migration files not needed at runtime are in dist already
